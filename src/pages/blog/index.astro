---
export const prerender = true;
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroGradient from "@/components/sections/HeroGradient.astro";
import BlockContainer from "@/components/global/BlockContainer.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import SkeletonBlogCard from "@/components/blog/SkeletonBlogCard.astro";

const seoMetaDatos = {
    title: "Snorkeling Adventure - Blog",
    description:
        "Get more information in our Blog for your next trip to Cancun and Riviera Maya. Any doubt you have, we will offer the answer.",
};

const dataPosts = {
    title: "Snorkeling Adventure - Blog",
    description: "Get more information in our Blog for your next trip to Cancun and Riviera Maya. Any doubt you have, we will offer the answer.",
};
---

<BaseLayout seo={seoMetaDatos} offI18n={true}>
    <HeroGradient
        title={dataPosts.title}
        text={dataPosts.description}
    />
    <BlockContainer>
        <!-- Categories -->
        <div class="w-full md:w-4/5 mx-auto">
            <p class="text-lg mb-10 text-center! font-semibold">Explore Categories</p>
        </div>
        <!-- Posts -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">
            <BlogCard server:defer>
                {
                    Array.from({ length: 12 }).map(() => (
                        <SkeletonBlogCard slot="fallback" />
                    ))
                }
            </BlogCard>
        </div>
    </BlockContainer>
</BaseLayout>
